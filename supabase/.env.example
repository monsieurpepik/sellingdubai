# supabase/.env.example — Local edge function secrets
# Copy to supabase/.env and fill in values.
# Used by: supabase functions serve --env-file ./supabase/.env
#
# THIS FILE IS FOR LOCAL DEVELOPMENT ONLY.
# Production secrets live in the Supabase dashboard (Project Settings → Edge Functions → Secrets).
# Never put real production values in this file.
#
# ⚠ PROD GUARD: scripts/dev.sh will ABORT if SUPABASE_URL is set to the prod URL.
#   Leave SUPABASE_URL blank — the edge runtime fills it automatically from `supabase start`.

# ── Supabase ──────────────────────────────────────────────────────────────────
# DO NOT set these to production values.
# The local emulator injects SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY automatically.
# Only set these here if you need to override (e.g. pointing a single function at a staging project).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used to build magic link URLs in emails.
# Set to your local frontend so Inbucket links open localhost, not production.
SITE_URL=http://127.0.0.1:8888

# ── Email — Resend ────────────────────────────────────────────────────────────
# Use a Resend test key (re_test_...) or leave blank.
# All outbound email is also captured locally at http://127.0.0.1:54324 (Inbucket).
RESEND_API_KEY=
RESEND_FROM=SellingDubai Local <dev@localhost>

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Leave blank locally — the webhook won't receive real events in dev.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WH_VERIFY_TOKEN=local-dev-token-change-me

# ── AI (Claude) ───────────────────────────────────────────────────────────────
# Optional — leave blank if not testing the whatsapp-ingest function.
ANTHROPIC_API_KEY=

# ── Social OAuth ──────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
# Use throwaway values locally — must never match production.
RATE_LIMIT_SALT=local-salt-replace-in-prod
CRON_SECRET=local-cron-secret
EXPORT_TOKEN=local-export-token
PLATFORM_OPS_EMAIL=dev@localhost

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use Stripe TEST keys (sk_test_..., whsec_test_...) — never live keys locally.
# Get test keys at: dashboard.stripe.com → Developers → API keys (toggle Test mode)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_

# ── Sentry (Edge Functions) ──────────────────────────────────────────────
# Same DSN as the browser SDK. Errors in edge functions will be sent here.
# Leave blank in local dev — errors will only go to console.
SENTRY_DSN=
