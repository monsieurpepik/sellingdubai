{
  "name": "sellingdubai-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "npx tailwindcss -i landing-input.css -o landing-output.css --minify",
    "build:js": "node scripts/build-js.js",
    "build:styles": "esbuild styles.css --bundle --minify --outfile=dist/styles.min.css",
    "clean": "rm -rf dist",
    "build": "npm run build:css && npm run build:js && npm run build:styles",
    "dev": "bash scripts/dev.sh",
    "check": "bash scripts/pre-deploy-check.sh",
    "test:functions": "PATH=\"$HOME/.deno/bin:$PATH\" deno test --config supabase/functions/deno.json --allow-net --allow-env --allow-read supabase/functions/*/test.ts supabase/functions/*/index.test.ts",
    "test": "npm run test:functions"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "esbuild": "^0.27.4",
    "netlify-cli": "^24.9.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2"
  }
}
