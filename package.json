{
  "name": "sellingdubai-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "npx tailwindcss -i landing-input.css -o landing-output.css --minify",
    "build:js": "node scripts/build-js.js",
    "build:styles": "esbuild styles.css --bundle --minify --outfile=dist/styles.min.css",
    "clean": "rm -rf dist",
    "build": "npm run build:css && npm run build:js && npm run build:styles",
    "dev": "bash scripts/dev.sh",
    "check": "bash scripts/pre-deploy-check.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "esbuild": "^0.27.4",
    "tailwindcss": "^3.4.17"
  }
}
